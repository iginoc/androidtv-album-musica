<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <FrameLayout
        android:id="@+id/main_browse_fragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/global_player_container"
        android:nextFocusRight="@+id/global_player_container"
        android:nextFocusDown="@+id/global_player_container" />

    <!-- Global Player Container -->
    <FrameLayout
        android:id="@+id/global_player_container"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_alignParentBottom="true"
        android:background="#E0000000"
        android:visibility="gone"
        android:elevation="10dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:descendantFocusability="afterDescendants" />

</RelativeLayout>